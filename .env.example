# MongoDB
MONGODB_URI=mongodb://localhost:27017/botguard

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production

# Node
NODE_ENV=development

# ========================================
# Frontend & Backend URLs (4 Services)
# ========================================

# 1. Detection Platform - Backend API (Runs on this port)
PORT=5000

# 2. Detection Platform - Frontend App
# -> The frontend itself runs on port 3000:
FRONTEND_PORT=3000
# -> Where the frontend sends its API data (points to the backend above):
REACT_APP_API_URL=http://localhost:5000
VITE_API_URL=http://localhost:5000

# 3. Bot Traffic Simulator - Backend API
SIMULATOR_PORT=5001
VITE_SIMULATOR_API_URL=http://localhost:5001

# 4. Bot Traffic Simulator - Frontend UI
# (Running on port 3001)
VITE_SIMULATOR_CLIENT_URL=http://localhost:3001

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
