{
  "name": "botguard-lab",
  "version": "1.0.0",
  "description": "AI-powered bot detection platform with behavior tracking and analysis",
  "private": true,
  "workspaces": [
    "bot-detection-platform/client",
    "bot-detection-platform/server",
    "bot-traffic-simulator/client",
    "bot-traffic-simulator/server"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,css}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "dev": "concurrently \"npm run dev --workspace=bot-detection-platform/server\" \"npm run dev --workspace=bot-detection-platform/client\"",
    "build": "npm run build --workspaces",
    "build:prod": "npm run build:prod --workspaces",
    "setup": "npm install && npm run setup:db",
    "setup:db": "npm run seed --workspace=bot-detection-platform/server"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "babel-jest": "^29.7.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
